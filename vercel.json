{
  "framework": "nextjs",
  "buildCommand": "npx prisma generate && next build",
  "env": {
    "DATABASE_URL": "@database_url",
    "NEXTAUTH_SECRET": "@nextauth_secret",
    "NEXTAUTH_URL": "@nextauth_url",
    "ANTHROPIC_API_KEY": "@anthropic_api_key",
    "SMTP_USER": "@smtp_user",
    "SMTP_PASS": "@smtp_pass"
  }
}
